# ─────────────────────────────────────────────────────────────────────
#  Learning Universe — environment variables (TEMPLATE)
#  Copy this file to .env.local and fill in your own keys.
#  Everything WITHOUT the NEXT_PUBLIC_ prefix is server-side ONLY and is
#  never exposed to the browser. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────────────

# ── OpenRouter (required) — runs most agent models ───────────────────
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://learning-universe-theta.vercel.app/
OPENROUTER_SITE_NAME=Learning Universe

# ── Web search (recommended) — powers the Research Agent ─────────────
# The agent is provider-agnostic. Pick ONE provider and give it a key.
#   SEARCH_PROVIDER : tavily | brave | serpapi | exa   (default: tavily)
#   SEARCH_API_KEY  : the key for the provider you chose
# Without a search key the agent still answers, but lowers its confidence
# and cannot cite live sources.
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=

# Legacy / per-provider keys (optional). Used only if SEARCH_API_KEY is unset,
# so existing Tavily setups keep working without changes.
#   Tavily  → https://tavily.com
#   Brave   → https://brave.com/search/api
#   SerpAPI → https://serpapi.com
#   Exa     → https://exa.ai
TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPAPI_API_KEY=
# EXA_API_KEY=

# ── Anthropic (optional) — enables Claude Opus 4.8 via the direct API ─
# When unset, the "Claude Opus 4.8 (Direct)" model falls back to OpenRouter.
ANTHROPIC_API_KEY=

# ── Embeddings (optional) — enables pgvector memory / RAG recall ─────
# An OpenAI key used only for text-embedding-3-small. Without it, memory
# still works via keyword recall.
EMBEDDING_API_KEY=

# ── App + Supabase ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
